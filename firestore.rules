rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica se o usuário autenticado é admin
    // Aceita custom claim (token) OU documento no Firestore (fallback sem Cloud Functions)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Coleção principal de processos
    match /atos-societarios/{processoId} {
      allow read: if true;
      // Admin pode criar, excluir e atualizar qualquer campo
      allow create, delete: if isAdmin();
      // Admin pode atualizar qualquer campo; cliente sem autenticação pode
      // atualizar apenas os campos do formulário, uma única vez
      // (formLinkUsado != true impede re-uso do link de edição)
      allow update: if isAdmin() || (
        resource.data.formLinkUsado != true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'dados', 'socios', 'preenchidoEm', 'atualizadoEm',
          'formLinkUsado', 'formLinkUsadoEm', 'etapas', 'arquivos', 'status'
        ])
      );
    }

    // Coleção de notificações internas
    match /notificacoes/{notifId} {
      // Qualquer origem (incluindo cliente não autenticado) pode criar
      allow create: if true;
      // Apenas usuários autenticados (contabilidade) podem ler e marcar como lida
      allow read, update: if request.auth != null;
      // Apenas admin pode excluir
      allow delete: if isAdmin();
    }

    // Coleção de usuários
    match /users/{userId} {
      // Leitura: próprio perfil ou admin
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Criação: apenas admin (app secundário cria o auth, admin escreve o doc)
      allow create: if isAdmin();
      // Atualização: próprio perfil ou admin
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Exclusão: apenas admin
      allow delete: if isAdmin();
    }
  }
}
