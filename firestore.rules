rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para a coleção de atos societários
    match /atos-societarios/{processoId} {
      // Qualquer pessoa pode ler (necessário para links de cliente e visualização pública)
      allow read: if true;

      // Apenas usuários autenticados com role=admin podem criar/editar/excluir
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Coleção de usuários (gerenciada pelo sistema)
    match /users/{userId} {
      // Usuário pode ler/editar próprio perfil; admin pode ler qualquer perfil
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
      allow update: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
      // Apenas admins podem criar/excluir usuários
      allow create, delete: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
